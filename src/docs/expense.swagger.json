{
  "paths": {
    "/api/expenses": {
      "post": {
        "summary": "Create expense",
        "tags": ["Expenses"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "amount": 500,
                "categoryId": "65f1a2b3c4d5e6f789012345",
                "note": "Lunch with friends",
                "date": "2026-03-23"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Expense created successfully",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Expense created successfully",
                  "data": {
                    "expense": {
                      "_id": "exp123",
                      "amount": 500,
                      "categoryId": {
                        "_id": "65f1a2b3c4d5e6f789012345",
                        "name": "Food"
                      },
                      "note": "Lunch with friends",
                      "date": "2026-03-23",
                      "userId": "user123",
                      "createdAt": "2026-03-23T10:00:00.000Z"
                    },
                    "warning": null
                  }
                }
              }
            }
          }
        }
      },

      "get": {
        "summary": "Get all expenses",
        "tags": ["Expenses"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "number", "example": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "number", "example": 10 }
          },
          {
            "name": "month",
            "in": "query",
            "schema": { "type": "number", "example": 3 }
          },
          {
            "name": "year",
            "in": "query",
            "schema": { "type": "number", "example": 2026 }
          }
        ],
        "responses": {
          "200": {
            "description": "Expenses fetched successfully",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Expenses fetched successfully",
                  "data": {
                    "total": 25,
                    "page": 1,
                    "limit": 10,
                    "data": [
                      {
                        "_id": "exp1",
                        "amount": 500,
                        "categoryId": {
                          "_id": "cat1",
                          "name": "Food"
                        },
                        "note": "Lunch",
                        "date": "2026-03-23"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },

    "/api/expenses/{id}": {
      "patch": {
        "summary": "Update expense",
        "tags": ["Expenses"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "exp123"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "amount": 700,
                "categoryId": "65f1a2b3c4d5e6f789012345",
                "note": "Dinner",
                "date": "2026-03-24"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Expense updated successfully",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Expense updated successfully",
                  "data": {
                    "_id": "exp123",
                    "amount": 700,
                    "categoryId": {
                      "_id": "cat1",
                      "name": "Food"
                    },
                    "note": "Dinner",
                    "date": "2026-03-24"
                  }
                }
              }
            }
          }
        }
      },

      "delete": {
        "summary": "Delete expense",
        "tags": ["Expenses"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "exp123"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Expense deleted successfully",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Expense deleted successfully",
                  "data": null
                }
              }
            }
          }
        }
      }
    },

    "/api/expenses/analytics": {
      "get": {
        "summary": "Get expense analytics",
        "tags": ["Expenses"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "month",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "example": 3 }
          },
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "example": 2026 }
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics data fetched",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Analytics fetched successfully",
                  "data": {
                    "totalSpent": 8500,
                    "categoryBreakdown": [
                      { "category": "Food", "total": 3000 },
                      { "category": "Travel", "total": 2000 }
                    ],
                    "topCategory": "Food",
                    "averageExpense": 850
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
